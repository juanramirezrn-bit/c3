using System;

class Program
{
    static void Main()
    {
        int total = 0;
        
        for (int i = 1; i <= 7; i++)
        {
            Console.Write("Ingrese vacunas del dia " + i + ": ");
            int cantidad = int.Parse(Console.ReadLine());
            total = total + cantidad;
        }

        double promedio = total / 7.0;

        Console.WriteLine("\n--- Reporte Final ---");
        Console.WriteLine("Total de vacunas: " + total);
        Console.WriteLine("Promedio diario: " + promedio);
    }
}
