using System;

class Program
{
    static void Main()
    {
        string[] nombres = new string[5];
        int[] cantidades = new int[5];
        for (int i = 0; i < 5; i++)
        {
         Console.Write("Nombre del medicamento " + (i + 1) + ": ");
         nombres[i] = Console.ReadLine();
         Console.Write("Cantidad: ");
         cantidades[i] = int.Parse(Console.ReadLine());
        }
        Console.WriteLine("\nInventario Completo:");
        for (int i = 0; i < 5; i++)
        {
            Console.WriteLine(nombres[i] + ": " + cantidades[i]);
        }
        int indiceMenor = 0;
        for (int i = 1; i < 5; i++)
        {
            if (cantidades[i] < cantidades[indiceMenor])
            {
                indiceMenor = i;
            }
        }
        Console.WriteLine("\nMedicamento con menos stock: " + nombres[indiceMenor] + " (" + cantidades[indiceMenor] + ")");
    }
}
